# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# PostHog analytics. Both vars are READ AT BUILD TIME by Vite — they get
# inlined into the bundle. Setting them in Railway runtime env does
# nothing; they must be present in the shell that runs `npm run build`.
#
# The project key (phc_...) is designed to be public — it's embedded in
# every client. Safe to commit if you want all builds to have analytics
# without each person setting up their own .env.local. Put it in
# frontend/.env.production for that.
#
# Host: https://us.i.posthog.com for US cloud, https://eu.i.posthog.com
# for EU cloud, or your self-hosted URL. Omit to default to US cloud.
VITE_PUBLIC_POSTHOG_KEY=phc_your_project_key_here
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
