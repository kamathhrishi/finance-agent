# agent — runtime corpus + state. NEVER commit.
# - data/filings/         The SEC filing corpus (~550MB, ~12k metadata.json files).
#                         On Railway: hydrated from S3 on cold start via
#                         agent/bootstrap.py (set
#                         FS_RESEARCH_BOOTSTRAP_FROM_S3=true). Locally: build
#                         it with `python -m agent.batch_ingest`.
# - data/_*.json          Watcher / index state files regenerated at runtime.
# - data/INDEX.md         Top-level corpus index, regenerated by ingest.
# - data/README.md        Auto-generated; agent reads it but ingest writes it.
agent/data
agent/data/
agent/logs/
agent/__pycache__/

# Legacy location — used to live here before the fs_research_agent → agent rename.
# Kept ignored so a stray local copy doesn't accidentally land in git.
fs_research_agent/

# agent benchmarks — data/ holds the downloaded SEC filings used by the
# benchmark runners. Source-of-truth for those is the FinanceBench HuggingFace
# dataset; the local copy is rebuildable via `python -m agent.benchmarks.financebench.download`.
# Never commit results/ or runs/ either — those are per-execution artefacts.
agent/benchmarks/**/data/
agent/benchmarks/**/results/
agent/benchmarks/**/runs/
agent/benchmarks/**/cache/

# Local sandboxes / scratch
explore/

# Claude Code per-project state — agent transcripts, hooks, settings.local.json
# (settings.json may be committed; the runtime keeps everything else local).
.claude/

